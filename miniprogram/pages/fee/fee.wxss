page { background: #f5f5f5; font-size: 28rpx; color: #333; }

/* 统计 */
.stats-row { display: flex; margin: 20rpx; gap: 16rpx; }
.stat-item { flex: 1; background: #fff; border-radius: 12rpx; padding: 24rpx 16rpx; text-align: center; }
.stat-num { display: block; font-size: 38rpx; font-weight: 700; color: #e53935; }
.stat-label { font-size: 24rpx; color: #999; margin-top: 8rpx; display: block; }

/* 分类统计 */
.category-section { background: #fff; margin: 0 20rpx 20rpx; border-radius: 12rpx; padding: 20rpx; }
.cat-item { display: flex; align-items: center; padding: 10rpx 0; }
.cat-name { width: 100rpx; font-size: 26rpx; }
.cat-bar-bg { flex: 1; height: 20rpx; background: #f0f0f0; border-radius: 10rpx; margin: 0 16rpx; overflow: hidden; }
.cat-bar { height: 100%; background: linear-gradient(90deg, #07c160, #e53935); border-radius: 10rpx; }
.cat-amount { width: 120rpx; text-align: right; font-size: 26rpx; color: #e53935; }

/* 扣费列表 */
.fee-list { margin: 0 20rpx; }
.fee-item { background: #fff; border-radius: 12rpx; padding: 24rpx; margin-bottom: 12rpx; position: relative; }
.fee-item.inactive { opacity: 0.5; }
.fee-top { display: flex; justify-content: space-between; align-items: center; }
.fee-platform { font-size: 32rpx; font-weight: 600; }
.fee-amount { font-size: 36rpx; color: #e53935; font-weight: 700; }
.fee-meta { display: flex; flex-wrap: wrap; gap: 16rpx; margin-top: 12rpx; color: #999; font-size: 24rpx; }
.fee-del { position: absolute; right: 24rpx; bottom: 24rpx; color: #e53935; font-size: 24rpx; padding: 8rpx; }

/* 空状态 */
.empty { text-align: center; padding: 80rpx 0; color: #999; }
.empty-sub { font-size: 24rpx; margin-top: 8rpx; display: block; }

/* 添加按钮 */
.add-btn-wrap { padding: 20rpx 20rpx 40rpx; }
.add-btn { width: 100%; background: #07c160; color: #fff; padding: 20rpx; border-radius: 12rpx; text-align: center; font-size: 30rpx; }

/* 表单弹窗 */
.modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.4); z-index: 100; display: none; }
.modal-overlay.show { display: block; }
.modal { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; border-radius: 24rpx 24rpx 0 0; padding: 40rpx 30rpx; z-index: 101; transform: translateY(100%); transition: transform 0.3s; }
.modal.show { transform: translateY(0); }
.modal-title { font-size: 34rpx; font-weight: 600; margin-bottom: 24rpx; }
.form-input { width: 100%; border: 2rpx solid #eee; border-radius: 8rpx; padding: 16rpx 20rpx; margin-bottom: 16rpx; box-sizing: border-box; }
.form-label { font-size: 26rpx; color: #666; margin-bottom: 12rpx; }
.option-row { display: flex; flex-wrap: wrap; gap: 12rpx; margin-bottom: 16rpx; }
.option { padding: 10rpx 24rpx; border-radius: 30rpx; background: #f5f5f5; font-size: 26rpx; color: #666; }
.option.active { background: #07c160; color: #fff; }
.modal-actions { display: flex; gap: 20rpx; margin-top: 20rpx; }
.btn-cancel { flex: 1; padding: 16rpx; border-radius: 8rpx; border: 2rpx solid #ddd; text-align: center; font-size: 28rpx; background: #fff; }
.btn-save { flex: 1; padding: 16rpx; border-radius: 8rpx; background: #07c160; color: #fff; text-align: center; font-size: 28rpx; }
