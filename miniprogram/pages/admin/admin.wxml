<navigation-bar title="后台管理" color="black" background="#fff" />
<scroll-view class="page" scroll-y>
  <view class="admin-tabs">
    <view class="admin-tab {{tab==='stats'?'active':''}}" bind:tap="switchTab" data-tab="stats">概览</view>
    <view class="admin-tab {{tab==='products'?'active':''}}" bind:tap="switchTab" data-tab="products">商品</view>
    <view class="admin-tab {{tab==='orders'?'active':''}}" bind:tap="switchTab" data-tab="orders">订单</view>
  </view>

  <!-- 概览 -->
  <view class="admin-content" wx:if="{{tab==='stats'}}">
    <view class="stat-grid">
      <view class="stat-card"><text class="stat-num">{{stats.user_count||0}}</text><text>用户数</text></view>
      <view class="stat-card"><text class="stat-num">{{stats.product_count||0}}</text><text>商品数</text></view>
      <view class="stat-card"><text class="stat-num">{{stats.order_count||0}}</text><text>订单数</text></view>
      <view class="stat-card"><text class="stat-num">¥{{stats.revenue||0}}</text><text>总收入</text></view>
    </view>
  </view>

  <!-- 商品管理 -->
  <view class="admin-content" wx:if="{{tab==='products'}}">
    <view class="product-item" wx:for="{{products}}" wx:key="id">
      <image class="p-img" src="{{item.image}}" mode="aspectFill" />
      <view class="p-info">
        <text class="p-name">{{item.name}}</text>
        <text>¥{{item.price}} | 库存 {{item.stock}} | 已售 {{item.sales}}</text>
      </view>
      <text class="p-status {{item.is_active?'':'inactive'}}">{{item.is_active?'上架':'下架'}}</text>
    </view>
  </view>

  <!-- 订单管理 -->
  <view class="admin-content" wx:if="{{tab==='orders'}}">
    <scroll-view class="order-filter" scroll-x>
      <view class="filter-item {{orderStatus===''?'active':''}}" bind:tap="selectOrderStatus" data-status="">全部</view>
      <view class="filter-item {{orderStatus==='pending'?'active':''}}" bind:tap="selectOrderStatus" data-status="pending">待付款</view>
      <view class="filter-item {{orderStatus==='paid'?'active':''}}" bind:tap="selectOrderStatus" data-status="paid">待发货</view>
      <view class="filter-item {{orderStatus==='shipped'?'active':''}}" bind:tap="selectOrderStatus" data-status="shipped">已发货</view>
      <view class="filter-item {{orderStatus==='completed'?'active':''}}" bind:tap="selectOrderStatus" data-status="completed">已完成</view>
    </scroll-view>
    <view class="order-item" wx:for="{{orders}}" wx:key="id">
      <view class="oi-header">
        <text>{{item.order_no}}</text>
        <text class="oi-status {{item.status}}">{{getStatusText(item.status)}}</text>
      </view>
      <text class="oi-user">用户ID: {{item.user_id}} | ¥{{item.total_amount}}</text>
      <view class="oi-actions" wx:if="{{item.status==='paid'}}">
        <button class="btn-action" bind:tap="updateStatus" data-id="{{item.id}}" data-status="shipped">发货</button>
      </view>
      <view class="oi-actions" wx:elif="{{item.status==='shipped'}}">
        <button class="btn-action" bind:tap="updateStatus" data-id="{{item.id}}" data-status="completed">完成</button>
      </view>
    </view>
  </view>
</scroll-view>
