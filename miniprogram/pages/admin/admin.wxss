page { background: #f5f5f5; }
.admin-tabs { display: flex; background: #fff; }
.admin-tab { flex: 1; text-align: center; padding: 20rpx; font-size: 28rpx; color: #666; border-bottom: 4rpx solid transparent; }
.admin-tab.active { color: #07c160; border-color: #07c160; }
.admin-content { padding: 16rpx; }
.stat-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.stat-card { width: 335rpx; background: #fff; border-radius: 12rpx; padding: 32rpx; text-align: center; }
.stat-num { font-size: 44rpx; font-weight: 700; color: #07c160; display: block; margin-bottom: 8rpx; }
.product-item { background: #fff; margin-bottom: 12rpx; padding: 20rpx; border-radius: 12rpx; display: flex; align-items: center; }
.p-img { width: 120rpx; height: 120rpx; border-radius: 8rpx; }
.p-info { flex: 1; margin: 0 16rpx; font-size: 24rpx; color: #999; }
.p-name { font-size: 28rpx; color: #333; display: block; margin-bottom: 8rpx; }
.p-status { font-size: 24rpx; color: #07c160; }
.p-status.inactive { color: #e53935; }
.order-filter { display: flex; white-space: nowrap; margin-bottom: 12rpx; }
.filter-item { display: inline-block; padding: 8rpx 24rpx; margin-right: 12rpx; border-radius: 30rpx; background: #fff; font-size: 24rpx; color: #666; }
.filter-item.active { background: #07c160; color: #fff; }
.order-item { background: #fff; margin-bottom: 12rpx; padding: 20rpx; border-radius: 12rpx; }
.oi-header { display: flex; justify-content: space-between; font-size: 24rpx; color: #999; }
.oi-status { font-weight: 600; }
.oi-status.pending { color: #f57c00; }
.oi-status.paid { color: #07c160; }
.oi-user { display: block; margin: 12rpx 0; font-size: 26rpx; }
.oi-actions { margin-top: 12rpx; }
.btn-action { display: inline-block; padding: 8rpx 28rpx; background: #07c160; color: #fff; border-radius: 6rpx; font-size: 24rpx; margin-right: 12rpx; }
