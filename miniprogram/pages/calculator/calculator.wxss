page {
  background: #f5f5f5;
  font-size: 28rpx;
  color: #333;
}
.card {
  background: #fff;
  margin: 20rpx;
  padding: 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.card-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}
.field {
  margin-bottom: 24rpx;
}
.label {
  display: block;
  margin-bottom: 12rpx;
  color: #666;
}
.input {
  border: 2rpx solid #eee;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  width: 100%;
  box-sizing: border-box;
}
.btn-primary {
  width: 100%;
  background: #07c160;
  color: #fff;
  border-radius: 8rpx;
  padding: 20rpx;
  text-align: center;
  margin-top: 16rpx;
  font-size: 30rpx;
}
.mode-tabs {
  display: flex;
  background: #f5f5f5;
  border-radius: 8rpx;
  overflow: hidden;
}
.mode-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  font-size: 28rpx;
}
.mode-tab.active {
  background: #07c160;
  color: #fff;
}
.method-tabs {
  display: flex;
  background: #f5f5f5;
  border-radius: 8rpx;
  overflow: hidden;
}
.method-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  font-size: 28rpx;
}
.method-tab.active {
  background: #07c160;
  color: #fff;
}
.result-item {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}
.result-item:last-child { border-bottom: none; }
.big { font-size: 36rpx; font-weight: 700; color: #e53935; }
.red { color: #e53935; font-weight: 600; }
.green { color: #07c160; font-weight: 600; }
.highlight { background: #fff3e0; margin: 0 -30rpx; padding: 16rpx 30rpx; }
.divider { height: 2rpx; background: #eee; margin: 12rpx 0; }
