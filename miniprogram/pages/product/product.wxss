page { background: #f5f5f5; }
.detail-img { width: 100%; }
.detail-info { background: #fff; padding: 30rpx; margin-bottom: 20rpx; }
.detail-name { font-size: 32rpx; font-weight: 600; }
.detail-price { margin: 16rpx 0; display: flex; align-items: baseline; }
.price-big { font-size: 44rpx; color: #e53935; font-weight: 700; }
.price-old { font-size: 26rpx; color: #999; text-decoration: line-through; margin-left: 12rpx; }
.detail-meta { display: flex; gap: 30rpx; color: #999; font-size: 24rpx; margin: 12rpx 0; }
.detail-desc { color: #666; font-size: 26rpx; margin-top: 16rpx; line-height: 1.6; }
.qty-bar {
  background: #fff; padding: 20rpx 30rpx; display: flex;
  justify-content: space-between; align-items: center; margin-bottom: 120rpx;
}
.qty-control { display: flex; align-items: center; }
.qty-btn {
  width: 60rpx; height: 60rpx; border: 2rpx solid #ddd; border-radius: 8rpx;
  text-align: center; line-height: 60rpx; font-size: 36rpx;
}
.qty-num { width: 80rpx; text-align: center; font-size: 32rpx; }
.action-bar {
  position: fixed; bottom: 0; left: 0; right: 0; display: flex;
  background: #fff; border-top: 2rpx solid #eee;
}
.action-cart {
  flex: 1; text-align: center; padding: 24rpx; color: #333;
  font-size: 30rpx; background: #fff;
}
.action-buy {
  flex: 1; text-align: center; padding: 24rpx; color: #fff;
  font-size: 30rpx; background: #07c160;
}
