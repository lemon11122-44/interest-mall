<navigation-bar title="商城" back="{{false}}" color="black" background="#fff" />
<scroll-view class="page" scroll-y>
  <scroll-view class="category-bar" scroll-x>
    <view class="cat-item {{category===''||category==='全部'?'active':''}}" bind:tap="selectCategory" data-cat="全部">全部</view>
    <view class="cat-item {{category===item?'active':''}}" wx:for="{{categories}}" wx:key="*this" bind:tap="selectCategory" data-cat="{{item}}">{{item}}</view>
  </scroll-view>

  <view class="product-grid">
    <view class="product-card" wx:for="{{products}}" wx:key="id" bind:tap="goProduct" data-id="{{item.id}}">
      <image class="product-img" src="{{item.image}}" mode="aspectFill" />
      <view class="product-name">{{item.name}}</view>
      <view class="product-price">
        <text class="price-current">¥{{item.discount_price||item.price}}</text>
        <text class="price-original" wx:if="{{item.discount_price}}">¥{{item.price}}</text>
      </view>
      <text class="sales">已售 {{item.sales}}</text>
    </view>
  </view>

  <view class="loading" wx:if="{{hasMore}}">
    <text>上拉加载更多</text>
  </view>
</scroll-view>
