page { background: #f5f5f5; }
.category-bar {
  display: flex; white-space: nowrap; background: #fff;
  padding: 16rpx 20rpx; margin-bottom: 8rpx;
}
.cat-item {
  display: inline-block; padding: 8rpx 28rpx; margin-right: 16rpx;
  border-radius: 30rpx; font-size: 26rpx; background: #f5f5f5; color: #666;
}
.cat-item.active { background: #07c160; color: #fff; }
.product-grid {
  display: flex; flex-wrap: wrap; padding: 0 10rpx;
}
.product-card {
  width: 345rpx; background: #fff; margin: 10rpx; border-radius: 12rpx;
  overflow: hidden; padding-bottom: 16rpx;
}
.product-img {
  width: 100%; height: 345rpx;
}
.product-name {
  font-size: 26rpx; margin: 12rpx 16rpx 0; overflow: hidden;
  text-overflow: ellipsis; white-space: nowrap;
}
.product-price { margin: 8rpx 16rpx; display: flex; align-items: baseline; }
.price-current { font-size: 32rpx; color: #e53935; font-weight: 600; }
.price-original { font-size: 22rpx; color: #999; text-decoration: line-through; margin-left: 8rpx; }
.sales { margin: 0 16rpx; font-size: 22rpx; color: #999; }
.loading { text-align: center; padding: 30rpx; color: #999; font-size: 26rpx; }
