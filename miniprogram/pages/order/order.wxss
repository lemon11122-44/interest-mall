page { background: #f5f5f5; }
.status-bar { display: flex; background: #fff; padding: 16rpx 20rpx; overflow-x: auto; white-space: nowrap; }
.status-item { display: inline-block; padding: 8rpx 24rpx; margin-right: 12rpx; border-radius: 30rpx; font-size: 26rpx; color: #666; background: #f5f5f5; }
.status-item.active { background: #07c160; color: #fff; }
.order-card { background: #fff; margin: 16rpx 20rpx; border-radius: 12rpx; overflow: hidden; }
.order-header { display: flex; justify-content: space-between; padding: 20rpx; border-bottom: 2rpx solid #f0f0f0; }
.order-no { font-size: 24rpx; color: #999; }
.order-status { font-size: 26rpx; font-weight: 600; }
.order-status.pending { color: #f57c00; }
.order-status.paid { color: #07c160; }
.order-status.shipped { color: #2196f3; }
.order-status.completed { color: #999; }
.order-status.cancelled { color: #e53935; }
.order-item { display: flex; padding: 16rpx 20rpx; border-bottom: 2rpx solid #f8f8f8; }
.oi-img { width: 120rpx; height: 120rpx; border-radius: 8rpx; }
.oi-info { flex: 1; margin-left: 16rpx; }
.oi-name { font-size: 26rpx; display: block; }
.oi-bottom { display: flex; justify-content: space-between; margin-top: 16rpx; color: #999; font-size: 24rpx; }
.order-footer { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 20rpx; font-size: 28rpx; font-weight: 600; }
.order-actions { display: flex; gap: 12rpx; }
.btn-sm { padding: 8rpx 24rpx; font-size: 24rpx; border-radius: 6rpx; background: #07c160; color: #fff; }
.btn-cancel { background: #fff; color: #666; border: 2rpx solid #ddd; }
.empty { text-align: center; padding: 100rpx 0; color: #999; font-size: 28rpx; }
