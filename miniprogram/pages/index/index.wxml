<view class="page">
  <!-- 顶部标题栏 -->
  <view class="header">
    <view class="header-left">
      <view class="logo-icon">%</view>
      <text class="header-title">IRR计算器</text>
    </view>
    <view class="header-right">
      <view class="capsule">
        <view class="capsule-item">···</view>
        <view class="capsule-divider"></view>
        <view class="capsule-item">☎</view>
      </view>
    </view>
  </view>

  <!-- 常用工具 -->
  <view class="section">
    <text class="section-title">常用工具</text>
    <view class="tool-grid">
      <view class="tool-row" wx:for="{{tools}}" wx:key="index">
        <view class="tool-item" wx:for="{{item}}" wx:for-item="tool" wx:key="id" data-id="{{tool.id}}" bind:tap="onToolTap" hover-class="tool-hover">
          <view class="tool-icon" style="background:{{tool.bg}}">
            <text class="tool-icon-text">{{tool.icon}}</text>
          </view>
          <text class="tool-name">{{tool.name}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 金融知识轮播 -->
  <view class="section">
    <text class="section-title">金融知识</text>
    <swiper class="banner-swiper" indicator-dots="{{true}}" indicator-color="#rgba(255,255,255,0.4)" indicator-active-color="#ffffff" autoplay="{{true}}" interval="5000" circular="{{true}}" bindchange="onBannerChange" bind:tap="onBannerTap">
      <swiper-item>
        <view class="banner-card" style="background:#FF44BB">
          <text class="banner-title">{{banner.title}}</text>
          <text class="banner-subtitle">{{banner.subtitle}}</text>
          <text class="banner-more">{{banner.more}}</text>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 底部安全区 -->
  <view class="bottom-safe"></view>

  <!-- 悬浮客服按钮 -->
  <view class="kf-float" bind:tap="onKfTap" hover-class="tool-hover">
    <text class="kf-icon">💬</text>
  </view>
</view>
