<navigation-bar title="购物车" back="{{false}}" color="black" background="#fff" />
<scroll-view class="page" scroll-y>
  <view class="empty" wx:if="{{isEmpty}}">
    <text class="empty-icon">🛒</text>
    <text class="empty-text">购物车是空的</text>
    <button class="btn-primary" bind:tap="goMall">去逛逛</button>
  </view>

  <view class="cart-item" wx:for="{{items}}" wx:key="id">
    <image class="cart-img" src="{{item.product_image}}" mode="aspectFill" />
    <view class="cart-info">
      <text class="cart-name">{{item.product_name}}</text>
      <text class="cart-price">¥{{item.discount_price||item.price}}</text>
      <view class="cart-qty">
        <text class="qty-btn" bind:tap="changeQty" data-id="{{item.id}}" data-delta="-1">-</text>
        <text class="qty-num">{{item.quantity}}</text>
        <text class="qty-btn" bind:tap="changeQty" data-id="{{item.id}}" data-delta="1">+</text>
      </view>
    </view>
    <text class="cart-del" bind:tap="removeItem" data-id="{{item.id}}">删除</text>
  </view>

  <view class="cart-footer" wx:if="{{!isEmpty}}">
    <text class="footer-total">合计: ¥{{total}}</text>
    <button class="btn-checkout" bind:tap="goOrder">去结算</button>
    <text class="btn-clear" bind:tap="clearCart">清空</text>
  </view>
</scroll-view>
